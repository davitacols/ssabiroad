# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_REGION_NAME=us-east-1
AWS_S3_BUCKET_NAME=your_bucket_name

# Service Configuration
PORT=8080
MAX_SYNC_LIMIT=50
MAX_RETRAIN_LIMIT=100
MAX_EVAL_LIMIT=20
ALLOWED_ORIGINS=*
NAVISENSE_V3_SCORE_GATE=0.78
NAVISENSE_V3_INFERENCE_TEMPERATURE=0.08
NAVISENSE_V3_TEXT_FUSION_WEIGHT=0.28
NAVISENSE_MULTIMODAL_PREFETCH=false

# Vision Backbone Configuration
# Default production baseline:
NAVISENSE_BACKBONE_MODEL=openai/clip-vit-base-patch32
# Optional explicit override if the backbone config cannot expose its own projection size:
# NAVISENSE_EMBEDDING_DIM=512
# Backward-compatible aliases supported by the service:
# NAVISENSE_CLIP_MODEL_NAME=
# NAVISENSE_MODEL_NAME=

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
# Keep the default baseline on the canonical index. For experiments, use a fresh index
# such as navisense-locations-geolocal-streetclip instead of reusing production vectors.
PINECONE_INDEX_NAME=navisense-locations

# Database Configuration - RDS (Primary)
POSTGRES_HOST=your_postgres_host
POSTGRES_DATABASE=ssabiroad
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# StreetCLIP experiment profile for NaviSense
# Use a fresh Pinecone index so StreetCLIP vectors do not mix with CLIP ViT-B/32 vectors.

NAVISENSE_BACKBONE_MODEL=geolocal/StreetCLIP
PINECONE_INDEX_NAME=navisense-locations-geolocal-streetclip
GEOLOCATION_MODEL_S3_KEY=navisense-ml-artifacts/streetclip/geolocation_model.pth
NAVISENSE_V3_S3_KEY=navisense-ml-artifacts/streetclip/navisense_v3.pth
ARCHITECTURAL_FEATURES_S3_KEY=navisense-ml-artifacts/streetclip/architectural_features.json

# Uncomment only if the model cannot report its own embedding size cleanly.
# NAVISENSE_EMBEDDING_DIM=512

# Keep the rest of the service configuration aligned with your main .env file:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=
# AWS_S3_BUCKET_NAME=
# PINECONE_API_KEY=
# POSTGRES_HOST=
# POSTGRES_DATABASE=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
